---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="inner">
    <span class="logo">⚡ SaaS Template</span>
    <div class="links">
      <a href="http://127.0.0.1:8000/docs" target="_blank">API Docs</a>
      <a href="http://localhost:4321/studio" target="_blank">CMS Studio</a>
      <a href="http://localhost:5173" target="_blank">Admin App</a>
    </div>
    <p class="copy">© {year} Modern SaaS Stack Template</p>
  </div>
</footer>

<style>
  .footer {
    background: #0f172a;
    border-top: 1px solid #1e293b;
    padding: 1.5rem 2rem;
  }
  .inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .logo {
    color: #38bdf8;
    font-weight: 800;
    font-size: 0.95rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .links {
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
    flex-shrink: 0;
  }
  .links a {
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.825rem;
    font-weight: 500;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .links a:hover { color: #f1f5f9; }
  .copy {
    color: #475569;
    font-size: 0.75rem;
    margin: 0;
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
