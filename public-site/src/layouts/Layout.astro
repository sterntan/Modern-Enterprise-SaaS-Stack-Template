---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Modern Enterprise SaaS Stack — FastAPI, Astro, Sanity, React" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <title>{title} | SaaS Template</title>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      :root {
        --primary: #38bdf8;
        --primary-dark: #0ea5e9;
        --bg: #f8fafc;
        --dark: #0f172a;
        --text: #1e293b;
        --muted: #64748b;
        --border: #e2e8f0;
      }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background-color: var(--bg);
        color: var(--text);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        line-height: 1.6;
      }
      /* Nav is position:sticky so sits at the top of the viewport always */
      main {
        flex: 1;
        padding: 3rem 2rem;
        max-width: 1100px;
        margin: 0 auto;
        width: 100%;
      }
      h1, h2, h3 { line-height: 1.2; margin-top: 0; }
      .btn {
        display: inline-block;
        padding: 0.75rem 1.75rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
      }
      .btn-primary { background: var(--primary); color: var(--dark); }
      .btn-primary:hover { background: var(--primary-dark); transform: translateY(-1px); }
      .btn-secondary { background: white; color: var(--dark); border: 2px solid var(--border); }
      .btn-secondary:hover { border-color: var(--primary); color: var(--primary); }
      label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 0.35rem;
        margin-top: 1rem;
      }
      input, select {
        width: 100%;
        padding: 0.65rem 0.9rem;
        border: 1.5px solid var(--border);
        border-radius: 6px;
        font-family: inherit;
        font-size: 0.95rem;
        color: var(--text);
        background: white;
        transition: border-color 0.2s;
      }
      input:focus, select:focus { outline: none; border-color: var(--primary); }
    </style>
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
