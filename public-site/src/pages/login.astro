---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login">
  <div class="login-container">
    <div class="login-card">
      <div class="brand">⚡</div>
      <h1>Welcome back</h1>
      <p>Sign in to access the admin dashboard.</p>

      <div id="errorMsg" class="error-msg" style="display:none;"></div>

      <form id="loginForm">
        <label for="email">Username / Email</label>
        <input type="text" id="email" placeholder="admin" value="admin" required />

        <label for="password">Password</label>
        <input type="password" id="password" placeholder="••••••••" value="admin" required />

        <button type="submit" id="loginBtn" class="btn btn-primary" style="width:100%; margin-top:1.25rem;">
          Sign In →
        </button>
      </form>

      <p class="demo-hint">
        <strong>Admin:</strong> <code>admin</code> / <code>admin</code><br/>
        <strong>User:</strong> <code>user</code> / <code>user</code>
      </p>

      <div class="divider">or</div>
      <a href="http://localhost:5173/" target="_blank" class="btn btn-secondary" style="width:100%; text-align:center; display:block;">
        Go directly to Dashboard →
      </a>
    </div>
  </div>
</Layout>

<script>
  document.getElementById('loginForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('loginBtn') as HTMLButtonElement;
    const errorDiv = document.getElementById('errorMsg') as HTMLDivElement;
    
    btn.innerText = 'Signing in...';
    btn.disabled = true;
    errorDiv.style.display = 'none';

    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    try {
      const res = await fetch('http://127.0.0.1:8000/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password })
      });

      if (res.ok) {
        const data = await res.json();
        const role = data?.user?.role;
        // Redirect based on role
        if (role === 'user') {
          window.location.href = 'http://localhost:5173/user';
        } else {
          window.location.href = 'http://localhost:5173/admin';
        }
      } else {
        const data = await res.json();
        errorDiv.innerText = data.detail || 'Invalid credentials. Please try again.';
        errorDiv.style.display = 'block';
        btn.innerText = 'Sign In →';
        btn.disabled = false;
      }
    } catch (err) {
      errorDiv.innerText = 'Could not reach the backend. Is it running on port 8000?';
      errorDiv.style.display = 'block';
      btn.innerText = 'Sign In →';
      btn.disabled = false;
    }
  });
</script>

<style>
  .login-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 120px);
    padding: 2rem 0;
  }
  .login-card {
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 16px;
    padding: 2.5rem;
    width: 100%;
    max-width: 420px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.07);
  }
  .brand {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  .login-card h1 {
    font-size: 1.6rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 0.25rem;
    letter-spacing: -0.5px;
  }
  .login-card > p {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .error-msg {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #dc2626;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  .demo-hint {
    text-align: center;
    font-size: 0.78rem;
    color: #94a3b8;
    margin-top: 1.25rem;
    line-height: 1.6;
  }
  code {
    background: #f1f5f9;
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-size: 0.85em;
    color: #334155;
  }
  .divider {
    text-align: center;
    color: #cbd5e1;
    font-size: 0.8rem;
    margin: 1.25rem 0;
    position: relative;
  }
  .divider::before, .divider::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 44%;
    height: 1px;
    background: var(--border);
  }
  .divider::before { left: 0; }
  .divider::after { right: 0; }
</style>
