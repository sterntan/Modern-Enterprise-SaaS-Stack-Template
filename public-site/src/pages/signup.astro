---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sign Up">
  <div class="signup-container">
    <h1>Get Started</h1>
    <p>Create an account to access the dashboard and APIs.</p>
    
    <div class="form-container">
      <form id="signupForm" class="signup-form">
        <label>First Name</label>
        <input type="text" id="firstName" placeholder="Jane" required />
        
        <label>Last Name</label>
        <input type="text" id="lastName" placeholder="Doe" required />

        <label>Email Address</label>
        <input type="email" id="email" placeholder="jane@example.com" required />
        
        <label>Role</label>
        <select id="role" style="width: 100%; padding: 0.5rem; margin-bottom: 1rem; border: 1px solid #ccc; border-radius: 4px;">
          <option value="user">Standard User</option>
          <option value="admin">Administrator</option>
        </select>
        
        <button type="submit" class="btn btn-primary" id="submitBtn" style="cursor: pointer; width: 100%;">Create Account</button>
      </form>
      <div id="successMsg" style="display: none; padding: 1rem; background: #dcfce7; color: #166534; border-radius: 0.5rem; margin-top: 1rem; text-align: center; font-weight: 500;">
        Success! Your account has been securely created in the PostgreSQL database. Head over to the React Admin App to view it.
      </div>
    </div>
  </div>
</Layout>

<script>
  document.getElementById('signupForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    if(btn) { btn.innerText = "Submitting..."; btn.disabled = true; }
    
    // Check if the backend is running first
    const payload = {
      first_name: document.getElementById('firstName').value,
      last_name: document.getElementById('lastName').value,
      email: document.getElementById('email').value,
      role: document.getElementById('role').value
    };

    try {
      const res = await fetch('http://127.0.0.1:8000/users/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      if (res.ok) {
        document.getElementById('signupForm').style.display = 'none';
        document.getElementById('successMsg').style.display = 'block';
      } else {
        const errData = await res.json();
        alert("Error creating account: " + JSON.stringify(errData));
        if(btn) { btn.innerText = "Create Account"; btn.disabled = false; }
      }
    } catch (err) {
      console.error(err);
      alert("Failed to connect to backend at http://127.0.0.1:8000. Is it running?");
      if(btn) { btn.innerText = "Create Account"; btn.disabled = false; }
    }
  });
</script>

<style>
  .signup-container {
    max-width: 460px;
    margin: 2rem auto;
  }
  .signup-container h1 {
    color: #0f172a;
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    letter-spacing: -0.5px;
  }
  .signup-container p {
    color: #64748b;
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }
  .form-container {
    background: white;
    border: 1.5px solid #e2e8f0;
    border-radius: 12px;
    padding: 2rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  }
  .signup-form {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
</style>
