---
import Layout from '../../layouts/Layout.astro';

// Placeholder for fetching from Sanity
// const products = await sanityClient.fetch('*[_type == "product"]');
const products = [
  { name: 'Starter Plan', description: 'Perfect for small teams.' },
  { name: 'Enterprise Plan', description: 'Full features and support.' }
];
---

<Layout title="Our Products">
  <h1>Our Products</h1>
  
  <div class="grid">
    {products.map(product => (
      <div class="card">
        <h2>{product.name}</h2>
        <p>{product.description}</p>
      </div>
    ))}
  </div>
</Layout>

<style>
  h1 { color: var(--primary); }
  .supplier-list {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .supplier-card {
    background: white;
    padding: 1.5rem;
    border-radius: 0.5rem;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }
  .supplier-card h2 { margin-top: 0; }
  .btn-outline {
    background: transparent;
    border: 1px solid var(--primary);
    color: var(--primary);
    padding: 0.5rem 1rem;
    border-radius: 0.25rem;
    cursor: pointer;
  }
  .btn-outline:hover {
    background: var(--primary);
    color: white;
  }
</style>
