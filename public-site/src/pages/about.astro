---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us">
  <div class="content">
    <h1>About Our Platform</h1>
    <p>We provide a modern SaaS template designed to accelerate your development and empower your business operations.</p>
  </div>
</Layout>

<style>
