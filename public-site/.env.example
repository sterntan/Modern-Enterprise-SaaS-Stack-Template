# ── Sanity CMS Data Client ───────────────────────────────────────────────
# These are used by @sanity/client to fetch content from your Sanity project.
# You do NOT need the Studio to be connected for this to work.
# The studio is a separate package — see /studio/.env.example
PUBLIC_SANITY_PROJECT_ID="your-project-id"
PUBLIC_SANITY_DATASET="production"
